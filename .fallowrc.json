{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "entry": [
    "bin/**/*.ts",
    "src/migrate/index.ts",
    "oxlint.config.ts",
    "examples/*/app.ts",
    "examples/*/storium.config.ts",
    "examples/*/seeds/**/*.ts",
    "examples/*/entities/**/*.store.ts"
  ],
  "ignorePatterns": [
    "dist/**",
    "examples/*/node_modules/**"
  ],
  "ignoreDependencies": [
    "better-sqlite3",
    "pg",
    "mysql2",
    "@libsql/client",
    "@testcontainers/mysql",
    "@testcontainers/postgresql",
    "fastify"
  ],
  "rules": {
    "unused-dev-dependencies": "error"
  },
  "duplicates": {
    "ignore": [
      "examples/**",
      "**/__tests__/**",
      "src/mixins/hasMany.ts",
      "src/mixins/hasOne.ts",
      "src/schema/zod.ts",
      "src/schema/json.ts"
    ]
  },
  "health": {
    "maxCyclomatic": 25,
    "maxCognitive": 25,
    "ignore": [
      "examples/**"
    ]
  }
}
